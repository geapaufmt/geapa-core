/**
 * ------------------------------------------------------------
 * Executa função protegida por Lock (evita concorrência).
 * ------------------------------------------------------------
 *
 * Quando usar:
 * - Jobs com trigger (time-driven).
 * - Processamento de e-mails.
 * - Qualquer rotina que NÃO pode rodar em paralelo.
 *
 * Problema que resolve:
 * - Dois gatilhos rodando ao mesmo tempo.
 * - Dupla execução enviando e-mails duplicados.
 * - Escrita concorrente em planilha.
 *
 * Parâmetros:
 * - key: identificador lógico do lock (uso conceitual/log).
 * - fn: função a ser executada dentro da seção crítica.
 * - timeoutMs: tempo máximo para tentar obter lock (padrão: 15s).
 *
 * Funcionamento:
 * 1) Tenta obter ScriptLock.
 * 2) Se não conseguir dentro do timeout -> lança erro.
 * 3) Executa a função protegida.
 * 4) Libera lock no bloco finally (garantido).
 *
 * Observação importante:
 * - Usa ScriptLock (escopo do projeto).
 * - NÃO funciona via Library com callback externo,
 *   porque funções não atravessam projetos.
 *
 * Exemplo de uso interno:
 *   core_withLock_('ANIVERSARIOS_JOB', () => {
 *       processarAniversarios();
 *   });
 */
function core_withLock_(key, fn, timeoutMs = 15000) {
  core_assertRequired_(key, 'Lock key');
  core_assertRequired_(fn, 'Lock fn');

  const lock = LockService.getScriptLock();
  const ok = lock.tryLock(timeoutMs);

  if (!ok) {
    throw new Error(
      `Lock não obtido (${key}). Execução concorrente em andamento.`
    );
  }

  try {
    return fn();
  } finally {
    lock.releaseLock();
  }
}
