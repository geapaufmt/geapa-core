/**
 * Retorna inlineImages padrão do GEAPA (logo)
 * Convenção do CID: "geapa_logo"
 */
function coreInlineImagesDefault() {
  return {
    geapa_logo: coreGetAssetBlob(GEAPA_ASSETS.BRAND.LOGO_GEAPA),
  };
}

/**
 * Envia e-mail HTML com inlineImages (merge seguro).
 * opts: {to, subject, htmlBody, cc?, bcc?, replyTo?, name?, inlineImages?}
 */
function coreSendHtmlEmail(opts) {
  const finalOpts = Object.assign({}, opts);

  // merge inlineImages (se houver)
  const baseInline = coreInlineImagesDefault();
  if (finalOpts.inlineImages) {
    finalOpts.inlineImages = Object.assign({}, baseInline, finalOpts.inlineImages);
  } else {
    finalOpts.inlineImages = baseInline;
  }

  MailApp.sendEmail(finalOpts);
}
